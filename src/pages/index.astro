---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import PortfolioBoard from "@components/PortfolioBoard";
import type { TagColor } from "@components/PortfolioBoard";
import { SITE, SOCIALS } from "@config";
import getSortedPosts from "@utils/getSortedPosts";
import getSortedWork from "@utils/getSortedWork";
import getSortedDemos from "@utils/getSortedDemos";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const homePostsRaw = (
  featuredPosts.length > 0 ? featuredPosts : sortedPosts
).slice(0, 6);

const works = await getCollection("work");
const sortedWorks = getSortedWork(works);
const featuredWorks = sortedWorks.filter(({ data }) => data.featured);
const homeWorksRaw = (
  featuredWorks.length > 0 ? featuredWorks : sortedWorks
).slice(0, 3);

const demos = await getCollection("demos");
const sortedDemos = getSortedDemos(demos);
const featuredDemos = sortedDemos.filter(({ data }) => data.featured);
const homeDemosRaw = (
  featuredDemos.length > 0 ? featuredDemos : sortedDemos
).slice(0, 4);

function formatPostDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

const TAG_COLORS: TagColor[] = ["red", "blue", "green"];

function tagColorFor(i: number): TagColor {
  return TAG_COLORS[i % TAG_COLORS.length]!;
}

const portfolioPosts = homePostsRaw.map((entry, i) => {
  const tag = entry.data.tags[0] ?? "Writing";
  return {
    id: entry.id,
    dateLabel: formatPostDate(entry.data.pubDatetime),
    dateTime: entry.data.pubDatetime.toISOString(),
    title: entry.data.title,
    desc: entry.data.description ?? "",
    tag,
    tagColor: tagColorFor(i),
    href: `/posts/${entry.slug}`,
  };
});

const portfolioWork = homeWorksRaw.map(entry => ({
  id: entry.id,
  label: entry.data.year ?? entry.data.tags[0] ?? "Work",
  name: entry.data.title,
  desc: entry.data.summary ?? entry.data.description ?? "",
  href: `/work/${entry.slug}`,
}));

const portfolioDemos = homeDemosRaw.map(entry => ({
  id: entry.id,
  title: entry.data.title,
  sub: entry.data.summary ?? entry.data.description ?? "",
  href: `/demos/${entry.slug}`,
}));

const github = SOCIALS.find(s => s.name === "Github" && s.active);
const linkedin = SOCIALS.find(s => s.name === "LinkedIn" && s.active);
---

<Layout>
  <PortfolioBoard
    client:load
    activePath={Astro.url.pathname}
    siteTitle={SITE.title}
    heroHeadline="I make the web feel like something."
    heroBody={SITE.desc}
    quote="Strong opinions, loosely held"
    posts={portfolioPosts}
    work={portfolioWork}
    demos={portfolioDemos}
    githubHref={github?.href ?? "https://github.com/rachelslurs"}
    linkedinHref={linkedin?.href ?? "https://www.linkedin.com/in/rachelcantor"}
  />
</Layout>
