---
import Pagination from "@components/Pagination.astro";
import WorkshopPegboard from "@components/workshop/WorkshopPegboard";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import { SITE } from "@config";
import type { GetStaticPaths, Page } from "astro";
import { getCollection } from "astro:content";
import getSortedWork from "@utils/getSortedWork";
import getSortedDemos from "@utils/getSortedDemos";
import getSortedLinks from "@utils/getSortedLinks";
import buildWorkshopPanels, {
  type WorkshopPanel,
} from "@utils/buildWorkshopPanels";
import { serializeWorkshopPanelsForPegboard } from "@utils/serializeWorkshopPegboard";

export const getStaticPaths = (async ({ paginate }) => {
  const work = getSortedWork(await getCollection("work"));
  const demos = getSortedDemos(await getCollection("demos"));
  const links = getSortedLinks(await getCollection("links"));

  const panels = buildWorkshopPanels(work, demos, links);
  const toPaginate = panels.length > 0 ? panels : [[]];

  return paginate(toPaginate, {
    pageSize: SITE.postPerPage,
    props: {
      workCount: work.length,
      demoCount: demos.length,
      linkCount: links.length,
    },
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<WorkshopPanel>;
  workCount: number;
  demoCount: number;
  linkCount: number;
}

const { page, workCount, demoCount, linkCount } = Astro.props;

const pegboardPanels = serializeWorkshopPanelsForPegboard(page.data ?? []);

const totalEntries = workCount + demoCount + linkCount;

const layoutTitle =
  page.currentPage > 1
    ? `Workshop (page ${page.currentPage}) | ${SITE.title}`
    : `Workshop | ${SITE.title}`;
---

<Layout title={layoutTitle}>
  <Main
    pageTitle="Workshop"
    pageDesc="Drag cards on the pegboard (desktop). Panels scroll horizontally; under 768px slabs stack with scale-to-fit. Paginated like the rest of the site."
  >
    <div
      class="not-prose mb-4 max-w-3xl font-body text-sm text-[var(--ink-muted)]"
    >
      <span class="text-[var(--ink-secondary)]">
        <strong class="font-mono text-[var(--black)]">{totalEntries}</strong> entries
      </span>
      <span class="mx-2 opacity-40" aria-hidden>·</span>
      work <strong class="font-mono">{workCount}</strong>
      <span class="mx-1.5 opacity-40" aria-hidden>·</span>
      demos <strong class="font-mono">{demoCount}</strong>
      <span class="mx-1.5 opacity-40" aria-hidden>·</span>
      links <strong class="font-mono">{linkCount}</strong>
      <span class="mx-1.5 opacity-40" aria-hidden>·</span>
      <strong class="font-mono">{page.total}</strong> panel{
        page.total === 1 ? "" : "s"
      } this page
    </div>

    <WorkshopPegboard client:load panels={pegboardPanels} />

    <Pagination page={page} />
  </Main>
</Layout>
