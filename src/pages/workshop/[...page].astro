---
import Pagination from "@components/Pagination.astro";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import { SITE } from "@config";
import type { GetStaticPaths, Page } from "astro";
import { getCollection } from "astro:content";
import getSortedWork from "@utils/getSortedWork";
import getSortedDemos from "@utils/getSortedDemos";
import getSortedLinks from "@utils/getSortedLinks";
import buildWorkshopPanels, {
  type WorkshopPanel,
  type WorkshopPanelItem,
} from "@utils/buildWorkshopPanels";
import { formatPostDate } from "@utils/mapBlogToPortfolioPost";
import {
  dumpDemoFields,
  dumpLinkFields,
  dumpWorkFields,
} from "@utils/workshopFieldDump";

export const getStaticPaths = (async ({ paginate }) => {
  const work = getSortedWork(await getCollection("work"));
  const demos = getSortedDemos(await getCollection("demos"));
  const links = getSortedLinks(await getCollection("links"));

  const panels = buildWorkshopPanels(work, demos, links);
  const toPaginate = panels.length > 0 ? panels : [[]];

  return paginate(toPaginate, {
    pageSize: SITE.postPerPage,
    props: {
      workCount: work.length,
      demoCount: demos.length,
      linkCount: links.length,
    },
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<WorkshopPanel>;
  workCount: number;
  demoCount: number;
  linkCount: number;
}

const { page, workCount, demoCount, linkCount } = Astro.props;

function sortTime(d: { pubDatetime: Date; modDatetime?: Date | null }) {
  return new Date(d.modDatetime ?? d.pubDatetime).getTime();
}

function itemToRow(item: WorkshopPanelItem) {
  switch (item.kind) {
    case "work":
      return {
        t: sortTime(item.entry.data),
        fields: dumpWorkFields(item.entry),
      };
    case "demos":
      return {
        t: sortTime(item.entry.data),
        fields: dumpDemoFields(item.entry),
      };
    case "links":
      return {
        t: sortTime(item.entry.data),
        fields: dumpLinkFields(item.entry),
      };
  }
}

function collectionAccent(c: string): {
  bar: string;
  badge: string;
  badgeText: string;
} {
  switch (c) {
    case "work":
      return {
        bar: "var(--blue)",
        badge: "rgba(0, 120, 191, 0.12)",
        badgeText: "var(--blue)",
      };
    case "demos":
      return {
        bar: "var(--yellow)",
        badge: "rgba(255, 181, 17, 0.2)",
        badgeText: "#9a7200",
      };
    case "links":
      return {
        bar: "var(--violet)",
        badge: "rgba(123, 104, 174, 0.15)",
        badgeText: "var(--violet)",
      };
    default:
      return {
        bar: "var(--ink-muted)",
        badge: "var(--cream)",
        badgeText: "var(--ink-secondary)",
      };
  }
}

function formatJsonBlock(v: unknown): string {
  return JSON.stringify(v, null, 2);
}

const totalEntries = workCount + demoCount + linkCount;

const layoutTitle =
  page.currentPage > 1
    ? `Workshop (page ${page.currentPage}) | ${SITE.title}`
    : `Workshop | ${SITE.title}`;
---

<Layout title={layoutTitle}>
  <Main
    pageTitle="Workshop"
    pageDesc="Field reference grouped into panels (max 4 items each: work → link → demos, then backfill), then paginated. Use this while building the pegboard UI."
  >
    <div class="workshop-ref not-prose max-w-3xl font-body">
      <div class="workshop-ref__stats">
        <span class="workshop-ref__stat">
          <strong>{totalEntries}</strong> entries
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          work <strong>{workCount}</strong>
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          demos <strong>{demoCount}</strong>
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          links <strong>{linkCount}</strong>
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          panels <strong>{page.total}</strong>
        </span>
      </div>

      <div class="workshop-ref__legend">
        <div class="workshop-ref__legend-card">
          <h2 class="workshop-ref__legend-title font-display">work</h2>
          <p class="workshop-ref__legend-body">
            title, summary, description, author, dates, year, featured, draft,
            tags, features[], ogImage, canonicalURL, slug, href
          </p>
        </div>
        <div class="workshop-ref__legend-card">
          <h2 class="workshop-ref__legend-title font-display">demos</h2>
          <p class="workshop-ref__legend-body">
            title, summary?, description?, author, dates, featured, draft,
            ogImage?, canonicalURL?, slug, href
          </p>
        </div>
        <div class="workshop-ref__legend-card">
          <h2 class="workshop-ref__legend-title font-display">links</h2>
          <p class="workshop-ref__legend-body">
            title, subtitle?, url, linkType, gifLink?, author, dates, draft,
            slug
          </p>
        </div>
      </div>

      {
        page.data.map((panel, panelIndex) => (
          <section
            class="workshop-ref__panel"
            aria-label={`Panel ${page.start + panelIndex + 1} of ${page.total}`}
          >
            <h2 class="workshop-ref__panel-title font-display">
              Panel {page.start + panelIndex + 1}
              <span class="workshop-ref__panel-count">
                {panel.length} item{panel.length === 1 ? "" : "s"}
              </span>
            </h2>
            {panel.length === 0 ? (
              <p class="workshop-ref__panel-empty">No entries yet.</p>
            ) : (
              <ul class="workshop-ref__list">
                {panel.map(item => {
                  const { t, fields } = itemToRow(item);
                  const accent = collectionAccent(fields.collection);
                  const href = String(
                    "href" in fields ? fields.href : (fields.url ?? "#")
                  );
                  const title = String(fields.title ?? "");
                  const linkType =
                    fields.collection === "links" && "linkType" in fields
                      ? String(fields.linkType)
                      : null;
                  return (
                    <li class="workshop-ref__item">
                      <article
                        class="workshop-ref__card card"
                        style={`border-left: 4px solid ${accent.bar}`}
                      >
                        <header class="workshop-ref__card-head">
                          <div class="workshop-ref__badges">
                            <span
                              class="workshop-ref__badge"
                              style={`background: ${accent.badge}; color: ${accent.badgeText}`}
                            >
                              {fields.collection}
                            </span>
                            {linkType ? (
                              <span class="workshop-ref__badge workshop-ref__badge--plain">
                                {linkType}
                              </span>
                            ) : null}
                          </div>
                          <h3 class="workshop-ref__card-title font-display">
                            <a href={href}>{title}</a>
                          </h3>
                          <p class="workshop-ref__card-meta">
                            <time datetime={new Date(t).toISOString()}>
                              {formatPostDate(new Date(t))}
                            </time>
                            <span class="workshop-ref__slug">
                              {fields.slug}
                            </span>
                          </p>
                        </header>

                        <dl class="workshop-ref__dl">
                          {(Object.entries(fields) as [string, unknown][]).map(
                            ([key, val]) => (
                              <>
                                <dt class="workshop-ref__dt">{key}</dt>
                                <dd class="workshop-ref__dd">
                                  {val === null || val === undefined ? (
                                    <span class="workshop-ref__empty">—</span>
                                  ) : key === "href" || key === "url" ? (
                                    <a
                                      href={String(val)}
                                      class="workshop-ref__link break-all"
                                    >
                                      {String(val)}
                                    </a>
                                  ) : key === "tags" &&
                                    Array.isArray(val) &&
                                    val.every(
                                      (x): x is string => typeof x === "string"
                                    ) ? (
                                    <ul class="workshop-ref__tags">
                                      {val.map(tag => (
                                        <li>{tag}</li>
                                      ))}
                                    </ul>
                                  ) : key === "features" &&
                                    Array.isArray(val) ? (
                                    <ul class="workshop-ref__features">
                                      {(
                                        val as {
                                          src: string;
                                          alt: string;
                                          caption?: string | null;
                                        }[]
                                      ).map(f => (
                                        <li>
                                          <span class="workshop-ref__feature-src">
                                            {f.src}
                                          </span>
                                          <span class="workshop-ref__feature-alt">
                                            {f.alt}
                                          </span>
                                          {f.caption ? (
                                            <span class="workshop-ref__feature-cap">
                                              {f.caption}
                                            </span>
                                          ) : null}
                                        </li>
                                      ))}
                                    </ul>
                                  ) : typeof val === "object" ? (
                                    <pre class="workshop-ref__pre">
                                      {formatJsonBlock(val)}
                                    </pre>
                                  ) : typeof val === "boolean" ? (
                                    <code class="workshop-ref__code">
                                      {val ? "true" : "false"}
                                    </code>
                                  ) : (
                                    <span class="workshop-ref__text">
                                      {String(val)}
                                    </span>
                                  )}
                                </dd>
                              </>
                            )
                          )}
                        </dl>
                      </article>
                    </li>
                  );
                })}
              </ul>
            )}
          </section>
        ))
      }

      <Pagination page={page} />
    </div>
  </Main>
</Layout>

<style>
  .workshop-ref {
    color: var(--ink-secondary);
  }
  .workshop-ref__stats {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem 1.5rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(var(--color-border) / 0.35);
    font-size: var(--riso-type-md);
  }
  .workshop-ref__stat strong {
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-lg);
    color: var(--black);
  }
  .workshop-ref__stat--muted {
    color: var(--ink-muted);
  }
  .workshop-ref__legend {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.25rem;
  }
  @media (min-width: 640px) {
    .workshop-ref__legend {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .workshop-ref__legend-card {
    background: var(--cream);
    padding: 1rem 1.125rem;
    border: 1px solid rgb(var(--color-border) / 0.45);
    box-shadow: 1px 2px 6px rgba(0, 0, 0, 0.08);
  }
  .workshop-ref__legend-title {
    margin: 0 0 0.5rem;
    font-size: var(--riso-type-title);
    font-weight: 400;
    color: var(--black);
    text-transform: lowercase;
  }
  .workshop-ref__legend-body {
    margin: 0;
    font-size: var(--riso-type-sm);
    line-height: var(--riso-leading-relaxed);
    color: var(--ink-muted);
  }
  .workshop-ref__panel {
    margin-bottom: 2.5rem;
  }
  .workshop-ref__panel:last-of-type {
    margin-bottom: 1rem;
  }
  .workshop-ref__panel-title {
    margin: 0 0 1rem;
    font-size: var(--riso-type-h4);
    font-weight: 400;
    color: var(--black);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 0.75rem;
  }
  .workshop-ref__panel-count {
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
  }
  .workshop-ref__panel-empty {
    margin: 0;
    font-size: var(--riso-type-sm);
    color: var(--ink-muted);
  }
  .workshop-ref__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .workshop-ref__card {
    margin: 0;
    padding: 1.25rem 1.35rem;
  }
  .workshop-ref__card-head {
    margin-bottom: 1.125rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed rgb(var(--color-border) / 0.5);
  }
  .workshop-ref__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    margin-bottom: 0.5rem;
  }
  .workshop-ref__badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .workshop-ref__badge--plain {
    background: var(--cream);
    color: var(--ink-muted);
    border: 1px solid rgb(var(--color-border) / 0.4);
  }
  .workshop-ref__card-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    font-weight: 400;
    line-height: 1.25;
  }
  .workshop-ref__card-title a {
    color: var(--black);
    text-decoration: none;
  }
  .workshop-ref__card-title a:hover {
    color: var(--red);
  }
  .workshop-ref__card-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
  }
  .workshop-ref__slug::before {
    content: "·";
    margin-right: 0.5rem;
    opacity: 0.5;
  }
  .workshop-ref__dl {
    display: grid;
    grid-template-columns: minmax(5.5rem, 32%) 1fr;
    gap: 0.35rem 1rem;
    margin: 0;
    font-size: var(--riso-type-sm);
    line-height: var(--riso-leading-snug);
  }
  @media (max-width: 480px) {
    .workshop-ref__dl {
      grid-template-columns: 1fr;
    }
    .workshop-ref__dt {
      margin-top: 0.5rem;
    }
    .workshop-ref__dt:first-child {
      margin-top: 0;
    }
  }
  .workshop-ref__dt {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    align-self: start;
    padding-top: 0.15rem;
  }
  .workshop-ref__dd {
    margin: 0;
    min-width: 0;
    word-break: break-word;
  }
  .workshop-ref__empty {
    color: var(--ink-muted);
    opacity: 0.65;
  }
  .workshop-ref__link {
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .workshop-ref__link:hover {
    color: var(--red);
  }
  .workshop-ref__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .workshop-ref__tags li {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    font-size: var(--riso-type-xs);
  }
  .workshop-ref__features {
    margin: 0;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .workshop-ref__features li {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: var(--riso-type-xs);
  }
  .workshop-ref__feature-src {
    font-family: ui-monospace, monospace;
    color: var(--blue);
    word-break: break-all;
  }
  .workshop-ref__feature-alt {
    color: var(--ink-secondary);
  }
  .workshop-ref__feature-cap {
    color: var(--ink-muted);
    font-style: italic;
  }
  .workshop-ref__pre {
    margin: 0;
    padding: 0.6rem 0.75rem;
    max-height: 14rem;
    overflow: auto;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    line-height: 1.45;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgb(var(--color-border) / 0.35);
    border-radius: 3px;
    white-space: pre-wrap;
  }
  .workshop-ref__code {
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-xs);
    padding: 0.1rem 0.35rem;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
  }
  .workshop-ref__text {
    font-size: var(--riso-type-sm);
  }
</style>
