---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import { SITE } from "@config";
import getSortedWork from "@utils/getSortedWork";
import getSortedDemos from "@utils/getSortedDemos";
import getSortedLinks from "@utils/getSortedLinks";
import { formatPostDate } from "@utils/mapBlogToPortfolioPost";
import {
  dumpDemoFields,
  dumpLinkFields,
  dumpWorkFields,
} from "@utils/workshopFieldDump";

const work = getSortedWork(await getCollection("work"));
const demos = getSortedDemos(await getCollection("demos"));
const links = getSortedLinks(await getCollection("links"));

function sortTime(d: { pubDatetime: Date; modDatetime?: Date | null }) {
  return new Date(d.modDatetime ?? d.pubDatetime).getTime();
}

const fieldRows = [
  ...work.map(entry => ({
    t: sortTime(entry.data),
    fields: dumpWorkFields(entry),
  })),
  ...demos.map(entry => ({
    t: sortTime(entry.data),
    fields: dumpDemoFields(entry),
  })),
  ...links.map(entry => ({
    t: sortTime(entry.data),
    fields: dumpLinkFields(entry),
  })),
].sort((a, b) => b.t - a.t);

type RowFields = (typeof fieldRows)[number]["fields"];

function collectionAccent(c: string): {
  bar: string;
  badge: string;
  badgeText: string;
} {
  switch (c) {
    case "work":
      return {
        bar: "var(--blue)",
        badge: "rgba(0, 120, 191, 0.12)",
        badgeText: "var(--blue)",
      };
    case "demos":
      return {
        bar: "var(--yellow)",
        badge: "rgba(255, 181, 17, 0.2)",
        badgeText: "#9a7200",
      };
    case "links":
      return {
        bar: "var(--violet)",
        badge: "rgba(123, 104, 174, 0.15)",
        badgeText: "var(--violet)",
      };
    default:
      return {
        bar: "var(--ink-muted)",
        badge: "var(--cream)",
        badgeText: "var(--ink-secondary)",
      };
  }
}

function formatJsonBlock(v: unknown): string {
  return JSON.stringify(v, null, 2);
}
---

<Layout title={`Workshop | ${SITE.title}`}>
  <Main
    pageTitle="Workshop"
    pageDesc="Field reference for work, demos, and links (newest first). Use this while building the pegboard UI."
  >
    <div class="workshop-ref not-prose max-w-3xl font-body">
      <div class="workshop-ref__stats">
        <span class="workshop-ref__stat">
          <strong>{fieldRows.length}</strong> entries
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          work <strong>{work.length}</strong>
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          demos <strong>{demos.length}</strong>
        </span>
        <span class="workshop-ref__stat workshop-ref__stat--muted">
          links <strong>{links.length}</strong>
        </span>
      </div>

      <div class="workshop-ref__legend">
        <div class="workshop-ref__legend-card">
          <h2 class="workshop-ref__legend-title font-display">work</h2>
          <p class="workshop-ref__legend-body">
            title, summary, description, author, dates, year, featured, draft,
            tags, features[], ogImage, canonicalURL, slug, href
          </p>
        </div>
        <div class="workshop-ref__legend-card">
          <h2 class="workshop-ref__legend-title font-display">demos</h2>
          <p class="workshop-ref__legend-body">
            title, summary?, description?, author, dates, featured, draft,
            ogImage?, canonicalURL?, slug, href
          </p>
        </div>
        <div class="workshop-ref__legend-card">
          <h2 class="workshop-ref__legend-title font-display">links</h2>
          <p class="workshop-ref__legend-body">
            title, subtitle?, url, linkType, gifLink?, author, dates, draft,
            slug
          </p>
        </div>
      </div>

      <ul class="workshop-ref__list">
        {
          fieldRows.map(({ t, fields }) => {
            const accent = collectionAccent(fields.collection);
            const href = String(
              "href" in fields ? fields.href : (fields.url ?? "#")
            );
            const title = String(fields.title ?? "");
            const linkType =
              fields.collection === "links" && "linkType" in fields
                ? String(fields.linkType)
                : null;
            return (
              <li class="workshop-ref__item">
                <article
                  class="workshop-ref__card card"
                  style={`border-left: 4px solid ${accent.bar}`}
                >
                  <header class="workshop-ref__card-head">
                    <div class="workshop-ref__badges">
                      <span
                        class="workshop-ref__badge"
                        style={`background: ${accent.badge}; color: ${accent.badgeText}`}
                      >
                        {fields.collection}
                      </span>
                      {linkType ? (
                        <span class="workshop-ref__badge workshop-ref__badge--plain">
                          {linkType}
                        </span>
                      ) : null}
                    </div>
                    <h2 class="workshop-ref__card-title font-display">
                      <a href={href}>{title}</a>
                    </h2>
                    <p class="workshop-ref__card-meta">
                      <time datetime={new Date(t).toISOString()}>
                        {formatPostDate(new Date(t))}
                      </time>
                      <span class="workshop-ref__slug">{fields.slug}</span>
                    </p>
                  </header>

                  <dl class="workshop-ref__dl">
                    {(Object.entries(fields) as [string, unknown][]).map(
                      ([key, val]) => (
                        <>
                          <dt class="workshop-ref__dt">{key}</dt>
                          <dd class="workshop-ref__dd">
                            {val === null || val === undefined ? (
                              <span class="workshop-ref__empty">—</span>
                            ) : key === "href" || key === "url" ? (
                              <a
                                href={String(val)}
                                class="workshop-ref__link break-all"
                              >
                                {String(val)}
                              </a>
                            ) : key === "tags" &&
                              Array.isArray(val) &&
                              val.every(
                                (x): x is string => typeof x === "string"
                              ) ? (
                              <ul class="workshop-ref__tags">
                                {val.map(tag => (
                                  <li>{tag}</li>
                                ))}
                              </ul>
                            ) : key === "features" && Array.isArray(val) ? (
                              <ul class="workshop-ref__features">
                                {(
                                  val as {
                                    src: string;
                                    alt: string;
                                    caption?: string | null;
                                  }[]
                                ).map(f => (
                                  <li>
                                    <span class="workshop-ref__feature-src">
                                      {f.src}
                                    </span>
                                    <span class="workshop-ref__feature-alt">
                                      {f.alt}
                                    </span>
                                    {f.caption ? (
                                      <span class="workshop-ref__feature-cap">
                                        {f.caption}
                                      </span>
                                    ) : null}
                                  </li>
                                ))}
                              </ul>
                            ) : typeof val === "object" ? (
                              <pre class="workshop-ref__pre">
                                {formatJsonBlock(val)}
                              </pre>
                            ) : typeof val === "boolean" ? (
                              <code class="workshop-ref__code">
                                {val ? "true" : "false"}
                              </code>
                            ) : (
                              <span class="workshop-ref__text">
                                {String(val)}
                              </span>
                            )}
                          </dd>
                        </>
                      )
                    )}
                  </dl>
                </article>
              </li>
            );
          })
        }
      </ul>
    </div>
  </Main>
</Layout>

<style>
  .workshop-ref {
    color: var(--ink-secondary);
  }
  .workshop-ref__stats {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem 1.5rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(var(--color-border) / 0.35);
    font-size: var(--riso-type-md);
  }
  .workshop-ref__stat strong {
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-lg);
    color: var(--black);
  }
  .workshop-ref__stat--muted {
    color: var(--ink-muted);
  }
  .workshop-ref__legend {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.25rem;
  }
  @media (min-width: 640px) {
    .workshop-ref__legend {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .workshop-ref__legend-card {
    background: var(--cream);
    padding: 1rem 1.125rem;
    border: 1px solid rgb(var(--color-border) / 0.45);
    box-shadow: 1px 2px 6px rgba(0, 0, 0, 0.08);
  }
  .workshop-ref__legend-title {
    margin: 0 0 0.5rem;
    font-size: var(--riso-type-title);
    font-weight: 400;
    color: var(--black);
    text-transform: lowercase;
  }
  .workshop-ref__legend-body {
    margin: 0;
    font-size: var(--riso-type-sm);
    line-height: var(--riso-leading-relaxed);
    color: var(--ink-muted);
  }
  .workshop-ref__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .workshop-ref__card {
    margin: 0;
    padding: 1.25rem 1.35rem;
  }
  .workshop-ref__card-head {
    margin-bottom: 1.125rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed rgb(var(--color-border) / 0.5);
  }
  .workshop-ref__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    margin-bottom: 0.5rem;
  }
  .workshop-ref__badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .workshop-ref__badge--plain {
    background: var(--cream);
    color: var(--ink-muted);
    border: 1px solid rgb(var(--color-border) / 0.4);
  }
  .workshop-ref__card-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    font-weight: 400;
    line-height: 1.25;
  }
  .workshop-ref__card-title a {
    color: var(--black);
    text-decoration: none;
  }
  .workshop-ref__card-title a:hover {
    color: var(--red);
  }
  .workshop-ref__card-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
  }
  .workshop-ref__slug::before {
    content: "·";
    margin-right: 0.5rem;
    opacity: 0.5;
  }
  .workshop-ref__dl {
    display: grid;
    grid-template-columns: minmax(5.5rem, 32%) 1fr;
    gap: 0.35rem 1rem;
    margin: 0;
    font-size: var(--riso-type-sm);
    line-height: var(--riso-leading-snug);
  }
  @media (max-width: 480px) {
    .workshop-ref__dl {
      grid-template-columns: 1fr;
    }
    .workshop-ref__dt {
      margin-top: 0.5rem;
    }
    .workshop-ref__dt:first-child {
      margin-top: 0;
    }
  }
  .workshop-ref__dt {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    align-self: start;
    padding-top: 0.15rem;
  }
  .workshop-ref__dd {
    margin: 0;
    min-width: 0;
    word-break: break-word;
  }
  .workshop-ref__empty {
    color: var(--ink-muted);
    opacity: 0.65;
  }
  .workshop-ref__link {
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .workshop-ref__link:hover {
    color: var(--red);
  }
  .workshop-ref__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .workshop-ref__tags li {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    font-size: var(--riso-type-xs);
  }
  .workshop-ref__features {
    margin: 0;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .workshop-ref__features li {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: var(--riso-type-xs);
  }
  .workshop-ref__feature-src {
    font-family: ui-monospace, monospace;
    color: var(--blue);
    word-break: break-all;
  }
  .workshop-ref__feature-alt {
    color: var(--ink-secondary);
  }
  .workshop-ref__feature-cap {
    color: var(--ink-muted);
    font-style: italic;
  }
  .workshop-ref__pre {
    margin: 0;
    padding: 0.6rem 0.75rem;
    max-height: 14rem;
    overflow: auto;
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-2xs);
    line-height: 1.45;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgb(var(--color-border) / 0.35);
    border-radius: 3px;
    white-space: pre-wrap;
  }
  .workshop-ref__code {
    font-family: ui-monospace, monospace;
    font-size: var(--riso-type-xs);
    padding: 0.1rem 0.35rem;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
  }
  .workshop-ref__text {
    font-size: var(--riso-type-sm);
  }
</style>
