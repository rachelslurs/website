---
import Layout from "@layouts/Layout.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";
import DetailPageScripts from "@components/DetailPageScripts.astro";
import Features from "@components/Features";
import TableOfContents from "@components/TableOfContents.astro";
import CollectionEntryHeader from "@components/CollectionEntryHeader.astro";
import PostFooterTagLinks from "@components/riso/PostFooterTagLinks";
import GhostEntryBack from "@components/riso/GhostEntryBack";
import GhostBackToTop from "@components/riso/GhostBackToTop";
import PostPagination from "@components/riso/PostPagination";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { filterTocHeadings } from "@utils/filterTocHeadings";
import { creativeWorkSchema } from "@utils/structuredData";
import { getCanonicalURL } from "@utils/canonicalURL";
import { resolveOgImage } from "@utils/ogImage";
import { SITE } from "@config";
export interface Props {
  work: CollectionEntry<"work">;
  works: CollectionEntry<"work">[];
}

const { work, works } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
  features,
  summary,
} = work.data;

const { Content, headings } = await work.render();

const og = resolveOgImage(
  ogImage,
  `/work/${slugifyStr(title)}.png`,
  Astro.url.origin
);

const pageUrl = canonicalURL ?? getCanonicalURL(Astro.url.pathname);

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description: description ?? summary,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: og.url,
  ogImageWidth: og.width,
  ogImageHeight: og.height,
  ogImageAlt: title,
  pageType: "article" as const,
  tags,
  breadcrumbName: title,
  structuredData: [
    creativeWorkSchema({
      title,
      description: description ?? summary,
      url: pageUrl,
      image: og.url,
      author,
      pubDatetime,
      modDatetime,
      tags,
    }),
  ],
};

const allWorks = works.map(({ data: { title: t }, slug }) => ({
  slug,
  title: t,
}));

const currentWorkIndex = allWorks.findIndex(a => a.slug === work.slug);

const prevWork = currentWorkIndex !== 0 ? allWorks[currentWorkIndex - 1] : null;
const nextWork =
  currentWorkIndex < allWorks.length - 1
    ? allWorks[currentWorkIndex + 1]
    : null;

const tagItems = tags.map(t => ({ slug: slugifyStr(t), label: t }));

const hasSidebarToc = filterTocHeadings(headings).length > 0;
---

<Layout {...layoutProps}>
  <RisoBoardShell>
    <main id="main-content" class="app-layout board-slot">
      <div class="toc-layout-grid">
        {
          hasSidebarToc && (
            <aside class="toc-sidebar">
              <TableOfContents headings={headings} />
            </aside>
          )
        }

        <!-- Main Content -->
        <article
          id="article"
          role="article"
          class="post-detail work-case-study w-full max-w-none"
        >
          <div class="analog-post">
            <div class="post-container">
              <div class="long-looseleaf tape-top-left tape-top-right">
                <div class="header-zone">
                  <GhostEntryBack fallbackHref="/work" client:visible />
                  <header class="post-header">
                    <CollectionEntryHeader
                      title={title}
                      summary={summary}
                      slug={work.slug}
                      variant="blog"
                      analogPostTitle
                    />
                  </header>
                </div>

                <div
                  class="analog-prose prose min-w-0 max-w-none prose-img:rounded prose-img:bg-skin-fill"
                >
                  {
                    features && features.length > 0 && (
                      <Features features={features} client:load />
                    )
                  }
                  <Content />
                </div>

                <div class="footer-zone">
                  <footer class="post-footer">
                    {
                      tagItems.length > 0 && (
                        <div class="post-tags">
                          <span class="post-tags-heading">Tech:</span>
                          <PostFooterTagLinks
                            items={tagItems}
                            basePath="/tech"
                            client:visible
                          />
                        </div>
                      )
                    }
                  </footer>
                  <GhostBackToTop client:visible />
                </div>

                <div
                  class="analog-post__tape-bottom tape-bottom-left tape-bottom-right"
                  aria-hidden="true"
                >
                </div>
              </div>

              <PostPagination
                prevPost={prevWork}
                nextPost={nextWork}
                hrefBase="/work"
                navLabel="Work navigation"
                client:visible
              />
            </div>
          </div>
        </article>
      </div>
    </main>
  </RisoBoardShell>
</Layout>

<style>
  main {
    @apply pb-12;
  }
</style>

<DetailPageScripts />
