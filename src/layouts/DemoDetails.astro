---
import Layout from "@layouts/Layout.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";
import CollectionEntryHeader from "@components/CollectionEntryHeader.astro";
import GhostEntryBack from "@components/riso/GhostEntryBack";
import PostPagination from "@components/riso/PostPagination";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { creativeWorkSchema } from "@utils/structuredData";
import { getCanonicalURL } from "@utils/canonicalURL";
import { resolveOgImage } from "@utils/ogImage";
import { SITE } from "@config";
export interface Props {
  demo: CollectionEntry<"demos">;
  demos: CollectionEntry<"demos">[];
}

const { demo, demos } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  summary,
} = demo.data;

const { Content } = await demo.render();

const og = resolveOgImage(
  ogImage,
  `/demos/${slugifyStr(title)}.png`,
  Astro.url.origin
);

const pageUrl = canonicalURL ?? getCanonicalURL(Astro.url.pathname);

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description: description ?? summary,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: og.url,
  ogImageWidth: og.width,
  ogImageHeight: og.height,
  ogImageAlt: title,
  pageType: "article" as const,
  breadcrumbName: title,
  structuredData: [
    creativeWorkSchema({
      title,
      description: description ?? summary,
      url: pageUrl,
      image: og.url,
      author,
      pubDatetime,
      modDatetime,
    }),
  ],
};

const allDemos = demos.map(({ data: { title: t }, slug }) => ({
  slug,
  title: t,
}));

const currentDemoIndex = allDemos.findIndex(a => a.slug === demo.slug);

const prevDemo = currentDemoIndex !== 0 ? allDemos[currentDemoIndex - 1] : null;
const nextDemo =
  currentDemoIndex < allDemos.length - 1
    ? allDemos[currentDemoIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <RisoBoardShell readingProgress>
    <main id="main-content" class="app-layout board-slot">
      <article
        id="article"
        role="article"
        class="post-detail w-full max-w-none mx-auto"
      >
        <div class="analog-post">
          <div class="post-container">
            <div class="long-looseleaf tape-top-left tape-top-right">
              <div class="header-zone">
                <GhostEntryBack fallbackHref="/demos" client:visible />
                <header class="post-header">
                  <CollectionEntryHeader
                    title={title}
                    summary={summary}
                    slug={demo.slug}
                    variant="blog"
                    analogPostTitle
                  />
                </header>
              </div>

              <div
                class="analog-prose prose min-w-0 max-w-none prose-img:rounded prose-img:bg-skin-fill"
              >
                <Content />
              </div>

              <div class="footer-zone">
                <footer class="post-footer"></footer>
              </div>

              <div
                class="analog-post__tape-bottom tape-bottom-left tape-bottom-right"
                aria-hidden="true"
              >
              </div>
            </div>

            <PostPagination
              prevPost={prevDemo}
              nextPost={nextDemo}
              hrefBase="/demos"
              navLabel="Demo navigation"
              client:visible
            />
          </div>
        </div>
      </article>
    </main>
  </RisoBoardShell>
</Layout>

<style>
  main {
    @apply pb-12;
  }
</style>
