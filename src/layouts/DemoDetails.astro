---
import Layout from "@layouts/Layout.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";
import TableOfContents from "@components/TableOfContents";
import CollectionEntryHeader from "@components/CollectionEntryHeader.astro";
import GhostEntryBack from "@components/riso/GhostEntryBack";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { SITE } from "@config";
export interface Props {
  demo: CollectionEntry<"demos">;
  demos: CollectionEntry<"demos">[];
}

const { demo, demos } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  summary,
} = demo.data;

const { Content } = await demo.render();

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/demos/${slugifyStr(title)}.png`,
  Astro.url.origin
).href;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
  scrollSmooth: true,
};

const allDemos = demos.map(({ data: { title: t }, slug }) => ({
  slug,
  title: t,
}));

const currentDemoIndex = allDemos.findIndex(a => a.slug === demo.slug);

const prevDemo = currentDemoIndex !== 0 ? allDemos[currentDemoIndex - 1] : null;
const nextDemo =
  currentDemoIndex < allDemos.length - 1
    ? allDemos[currentDemoIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <RisoBoardShell>
    <main id="main-content" class="app-layout board-slot">
      <div class="toc-layout-grid">
        <aside class="toc-sidebar">
          <TableOfContents client:load />
        </aside>

        <article
          id="article"
          role="article"
          class="post-detail w-full max-w-none"
        >
          <div class="analog-post">
            <div class="post-container">
              <div class="long-looseleaf tape-top-left tape-top-right">
                <div class="header-zone">
                  <GhostEntryBack fallbackHref="/demos" client:load />
                  <header class="post-header">
                    <CollectionEntryHeader
                      title={title}
                      summary={summary}
                      slug={demo.slug}
                      variant="blog"
                      analogPostTitle
                    />
                  </header>
                </div>

                <div
                  class="prose analog-prose max-w-none min-w-0 prose-img:rounded prose-img:bg-skin-fill"
                >
                  <Content />
                </div>

                <div class="footer-zone">
                  <footer class="post-footer"></footer>
                </div>

                <div
                  class="analog-post__tape-bottom tape-bottom-left tape-bottom-right"
                  aria-hidden="true"
                >
                </div>
              </div>
            </div>
          </div>
        </article>
      </div>

      <hr class="my-6 border-dashed" />

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          prevDemo && (
            <a
              href={`/demos/${prevDemo.slug}`}
              class="flex w-full gap-1 hover:opacity-75"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-left flex-none"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M15 6l-6 6l6 6" />
              </svg>
              <div>
                <span>Previous</span>
                <div class="text-sm text-skin-accent/85">{prevDemo.title}</div>
              </div>
            </a>
          )
        }
        {
          nextDemo && (
            <a
              href={`/demos/${nextDemo.slug}`}
              class="flex w-full justify-end gap-1 text-right hover:opacity-75 sm:col-start-2"
            >
              <div>
                <span>Next</span>
                <div class="text-sm text-skin-accent/85">{nextDemo.title}</div>
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-right flex-none"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M9 6l6 6l-6 6" />
              </svg>
            </a>
          )
        }
      </div>
    </main>
  </RisoBoardShell>
</Layout>

<style>
  main {
    @apply pb-12;
  }
</style>

<script is:inline>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container pointer-events-none fixed top-0 z-[9999] h-1 w-full bg-transparent";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-skin-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    const winScroll =
      document.body.scrollTop || document.documentElement.scrollTop;
    const height =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    if (document) {
      const myBar = document.getElementById("myBar");
      if (myBar) {
        myBar.style.width = scrolled + "%";
      }
    }
  }
  document.addEventListener("scroll", updateScrollProgress);

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily.
   *  Excludes headings with data-exclude-heading-link or inside astro-island
   *  so we don't mutate DOM that React will hydrate. */
  function addHeadingLinks() {
    let headings = Array.from(
      document.querySelectorAll(
        "h2, h3:not([data-exclude-heading-link]), h4:not([data-exclude-heading-link]), h5:not([data-exclude-heading-link]), h6:not([data-exclude-heading-link])"
      )
    ).filter(h => !h.closest("astro-island"));

    for (let heading of headings) {
      heading.classList.add("group");
      let link = document.createElement("a");
      link.className = "ml-2 heading-link";
      let linkSpan = document.createElement("span");
      linkSpan.innerText = "#";
      let ariaText = document.createElement("span");
      ariaText.className = "sr-only focus:not-sr-only";
      ariaText.innerText = `Link to section titled: ${heading.textContent}`;
      link.href = "#" + heading.id;
      link.appendChild(ariaText);
      link.appendChild(linkSpan);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    let copyButtonLabel = "Copy";
    let codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (let codeBlock of codeBlocks) {
      let wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      let copyButton = document.createElement("button");
      copyButton.className =
        "copy-code absolute right-3 top-0 rounded bg-skin-card px-2 py-1 text-xs leading-4 text-skin-base font-medium";
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      let code = block.querySelector("code");
      let text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();
</script>
