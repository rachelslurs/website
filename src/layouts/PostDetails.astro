---
import Layout from "@layouts/Layout.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";
import Datetime from "@components/Datetime";
import PostFooterTagLinks from "@components/riso/PostFooterTagLinks";
import TableOfContents from "@components/TableOfContents.astro";
import CollectionEntryHeader from "@components/CollectionEntryHeader.astro";
import GhostEntryBack from "@components/riso/GhostEntryBack";
import GhostBackToTop from "@components/riso/GhostBackToTop";
import PostPagination from "@components/riso/PostPagination";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { filterTocHeadings } from "@utils/filterTocHeadings";
import { SITE } from "@config";
export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content, headings } = await post.render();

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/posts/${slugifyStr(title)}.png`,
  Astro.url.origin
).href;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, slug }) => ({
  slug,
  title,
}));

const currentPostIndex = allPosts.findIndex(a => a.slug === post.slug);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

const tagItems = tags.map(t => ({ slug: slugifyStr(t), label: t }));

const hasSidebarToc = filterTocHeadings(headings).length > 0;
---

<Layout {...layoutProps}>
  <!-- <div class="progress-container pointer-events-none fixed top-0 z-[9999] h-1 w-full bg-transparent">
    <div class="progress-bar h-1 w-0 bg-skin-accent" id="myBar"></div>
  </div> -->

  <RisoBoardShell>
    <main id="main-content" class="app-layout board-slot">
      <div class="toc-layout-grid">
        {
          hasSidebarToc && (
            <aside class="toc-sidebar">
              <TableOfContents headings={headings} />
            </aside>
          )
        }

        <!-- Main Content -->
        <article
          id="article"
          role="article"
          class="post-detail w-full max-w-none"
        >
          <div class="analog-post">
            <div class="post-container">
              <div class="long-looseleaf tape-top-left tape-top-right">
                <div class="header-zone">
                  <GhostEntryBack fallbackHref="/posts" client:visible />
                  <header class="post-header">
                    <Datetime
                      pubDatetime={pubDatetime}
                      modDatetime={modDatetime}
                      variant="analog"
                    />
                    <CollectionEntryHeader
                      title={title}
                      slug={post.slug}
                      variant="blog"
                      analogPostTitle
                    />
                  </header>
                </div>

                <div
                  class="prose prose-analog min-w-0 max-w-none prose-img:rounded prose-img:bg-skin-fill"
                >
                  <Content />
                </div>

                <div class="footer-zone">
                  <footer class="post-footer">
                    {
                      tagItems.length > 0 && (
                        <div class="post-tags">
                          <span class="post-tags-heading">Tags:</span>
                          <PostFooterTagLinks items={tagItems} client:visible />
                        </div>
                      )
                    }
                  </footer>
                  <GhostBackToTop client:visible />
                </div>

                <div
                  class="analog-post__tape-bottom tape-bottom-left tape-bottom-right"
                  aria-hidden="true"
                >
                </div>
              </div>

              <PostPagination
                prevPost={prevPost}
                nextPost={nextPost}
                client:visible
              />
            </div>
          </div>
        </article>
      </div>
    </main>
  </RisoBoardShell>
</Layout>

<style>
  main {
    @apply pb-12;
  }
</style>

<script is:inline>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container pointer-events-none fixed top-0 z-[9999] h-1 w-full bg-transparent";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-skin-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    const winScroll =
      document.body.scrollTop || document.documentElement.scrollTop;
    const height =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    if (document) {
      const myBar = document.getElementById("myBar");
      if (myBar) {
        myBar.style.width = scrolled + "%";
      }
    }
  }
  document.addEventListener("scroll", updateScrollProgress, { passive: true });

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily.
   *  Excludes headings with data-exclude-heading-link or inside astro-island
   *  so we don't mutate DOM that React will hydrate. */
  function addHeadingLinks() {
    let headings = Array.from(
      document.querySelectorAll(
        "h2, h3:not([data-exclude-heading-link]), h4:not([data-exclude-heading-link]), h5:not([data-exclude-heading-link]), h6:not([data-exclude-heading-link])"
      )
    ).filter(
      h =>
        !h.closest("astro-island") &&
        typeof h.id === "string" &&
        h.id.length > 0
    );

    for (let heading of headings) {
      heading.classList.add("group");
      let link = document.createElement("a");
      link.className = "ml-2 heading-link";
      const clone = heading.cloneNode(true);
      clone.querySelectorAll(".heading-link").forEach(el => el.remove());
      const sectionTitle = (clone.textContent ?? "").replace(/#/g, "").trim();
      link.setAttribute(
        "aria-label",
        sectionTitle
          ? `Link to section: ${sectionTitle}`
          : "Link to this section"
      );
      link.href = "#" + heading.id;
      let linkSpan = document.createElement("span");
      linkSpan.textContent = "#";
      linkSpan.setAttribute("aria-hidden", "true");
      link.appendChild(linkSpan);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    let copyButtonLabel = "Copy";
    let codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (let codeBlock of codeBlocks) {
      let wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      let copyButton = document.createElement("button");
      copyButton.className =
        "copy-code absolute right-3 top-3 rounded bg-skin-card px-2 py-1 text-xs leading-4 text-skin-base font-medium";
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      let code = block.querySelector("code");
      let text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();
</script>
