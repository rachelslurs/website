---
import Layout from "@layouts/Layout.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";
import DetailPageScripts from "@components/DetailPageScripts.astro";
import Datetime from "@components/Datetime";
import PostFooterTagLinks from "@components/riso/PostFooterTagLinks";
import TableOfContents from "@components/TableOfContents.astro";
import CollectionEntryHeader from "@components/CollectionEntryHeader.astro";
import GhostEntryBack from "@components/riso/GhostEntryBack";
import GhostBackToTop from "@components/riso/GhostBackToTop";
import PostPagination from "@components/riso/PostPagination";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { filterTocHeadings } from "@utils/filterTocHeadings";
import { blogPostingSchema } from "@utils/structuredData";
import { getCanonicalURL } from "@utils/canonicalURL";
import { resolveOgImage } from "@utils/ogImage";
import { SITE } from "@config";
export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content, headings } = await post.render();

const og = resolveOgImage(
  ogImage,
  `/posts/${slugifyStr(title)}.png`,
  Astro.url.origin
);

const pageUrl = canonicalURL ?? getCanonicalURL(Astro.url.pathname);
const wordCount = post.body?.trim().split(/\s+/).length;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: og.url,
  ogImageWidth: og.width,
  ogImageHeight: og.height,
  ogImageAlt: title,
  pageType: "article" as const,
  tags,
  breadcrumbName: title,
  structuredData: [
    blogPostingSchema({
      title,
      description,
      url: pageUrl,
      image: og.url,
      author,
      pubDatetime,
      modDatetime,
      tags,
      wordCount,
    }),
  ],
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, slug }) => ({
  slug,
  title,
}));

const currentPostIndex = allPosts.findIndex(a => a.slug === post.slug);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

const tagItems = tags.map(t => ({ slug: slugifyStr(t), label: t }));

const hasSidebarToc = filterTocHeadings(headings).length > 0;
---

<Layout {...layoutProps}>
  <!-- <div class="progress-container pointer-events-none fixed top-0 z-[9999] h-1 w-full bg-transparent">
    <div class="progress-bar h-1 w-0 bg-skin-accent" id="myBar"></div>
  </div> -->

  <RisoBoardShell>
    <main id="main-content" class="app-layout board-slot">
      <div class="toc-layout-grid">
        {
          hasSidebarToc && (
            <aside class="toc-sidebar">
              <TableOfContents headings={headings} />
            </aside>
          )
        }

        <!-- Main Content -->
        <article
          id="article"
          role="article"
          class="post-detail w-full max-w-none"
        >
          <div class="analog-post">
            <div class="post-container">
              <div class="long-looseleaf tape-top-left tape-top-right">
                <div class="header-zone">
                  <GhostEntryBack fallbackHref="/posts" client:visible />
                  <header class="post-header">
                    <Datetime
                      pubDatetime={pubDatetime}
                      modDatetime={modDatetime}
                      variant="analog"
                    />
                    <CollectionEntryHeader
                      title={title}
                      slug={post.slug}
                      variant="blog"
                      analogPostTitle
                    />
                  </header>
                </div>

                <div
                  class="analog-prose prose min-w-0 max-w-none prose-img:rounded prose-img:bg-skin-fill"
                >
                  <Content />
                </div>

                <div class="footer-zone">
                  <footer class="post-footer">
                    {
                      tagItems.length > 0 && (
                        <div class="post-tags">
                          <span class="post-tags-heading">Tags:</span>
                          <PostFooterTagLinks items={tagItems} client:visible />
                        </div>
                      )
                    }
                  </footer>
                  <GhostBackToTop client:visible />
                </div>

                <div
                  class="analog-post__tape-bottom tape-bottom-left tape-bottom-right"
                  aria-hidden="true"
                >
                </div>
              </div>

              <PostPagination
                prevPost={prevPost}
                nextPost={nextPost}
                client:visible
              />
            </div>
          </div>
        </article>
      </div>
    </main>
  </RisoBoardShell>
</Layout>

<style>
  main {
    @apply pb-12;
  }
</style>

<DetailPageScripts />
