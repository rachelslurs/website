---
import { SITE } from "@config";
import { profilePageSchema } from "@utils/structuredData";
import Layout from "./Layout.astro";
import Main from "./Main.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
    activeNav?: "posts" | "about" | "search" | "work" | "demos";
  };
}

const { frontmatter } = Astro.props;

const structuredData =
  frontmatter.activeNav === "about" ? [profilePageSchema()] : [];
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  description={frontmatter.description}
  structuredData={structuredData}
>
  <Main
    pageTitle={frontmatter.title}
    showPageHeader={false}
    showBreadcrumbs={false}
  >
    <h1 class="mb-4">{frontmatter.title}</h1>
    <section class="mb-28 mt-4 prose-img:border-0">
      <slot />
    </section>
  </Main>
</Layout>
