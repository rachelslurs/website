---
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Layout from "./Layout.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
    activeNav?: "posts" | "about" | "search" | "work" | "demos";
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <RisoBoardShell>
    <Breadcrumbs />
    <main
      id="main-content"
      class="board-slot app-layout prose prose-analog max-w-none prose-img:rounded prose-img:bg-skin-fill"
    >
      <h1 class="mb-4">{frontmatter.title}</h1>
      <section class="mb-28 mt-4">
        <slot />
      </section>
    </main>
  </RisoBoardShell>
</Layout>
