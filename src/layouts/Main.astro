---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import RisoBoardShell from "@components/RisoBoardShell.astro";

interface StringTitleProp {
  pageTitle: string;
  pageDesc?: string;
  includeRss?: boolean;
  /** When `false`, breadcrumb trail is omitted (e.g. posts index). Default: show. */
  showBreadcrumbs?: boolean;
  /** When `false`, skip page h1, description, and RSS row (e.g. posts index). Default: show. */
  showPageHeader?: boolean;
  /**
   * When true: board shell + main use a flex height chain so workshop pegboard
   * scrolls inside the viewport (ADR-003 — frame arrows visible without page scroll).
   */
  fillViewportSlot?: boolean;
}

interface ArrayTitleProp {
  pageTitle: [string, string];
  titleTransition: string;
  pageDesc?: string;
  includeRss?: boolean;
  showBreadcrumbs?: boolean;
  showPageHeader?: boolean;
  fillViewportSlot?: boolean;
}

export type Props = StringTitleProp | ArrayTitleProp;

const { props } = Astro;
const showBreadcrumbs = props.showBreadcrumbs !== false;
const showPageHeader = props.showPageHeader !== false;
const fillViewportSlot = props.fillViewportSlot === true;
---

<RisoBoardShell
  fillViewportChain={fillViewportSlot}
  immersivePegStage={fillViewportSlot}
>
  {showBreadcrumbs && <Breadcrumbs />}
  <main
    id="main-content"
    class:list={[
      "board-slot app-layout max-w-none",
      !fillViewportSlot &&
        "prose prose-analog max-sm:prose-sm prose-img:rounded prose-img:bg-skin-fill",
      fillViewportSlot && "workshop-viewport-slot flex min-h-0 flex-1 flex-col",
    ]}
  >
    {
      showPageHeader && (
        <>
          {"titleTransition" in props ? (
            <h1 class="mb-0 flex items-center justify-between">
              <span>
                {props.pageTitle[0]}
                <span transition:name={props.titleTransition}>
                  {props.pageTitle[1]}
                </span>
              </span>
              {props.includeRss && (
                <a
                  target="_blank"
                  href="/rss.xml"
                  class="rss-link inline-flex items-center"
                  aria-label="rss feed"
                  title="RSS Feed"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="rss-icon inline"
                  >
                    <path d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z" />
                    <path d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z" />
                    <circle cx="6" cy="18" r="2" />
                  </svg>
                  <span class="sr-only">RSS Feed</span>
                </a>
              )}
            </h1>
          ) : (
            <h1 class="mb-1 flex items-center justify-between">
              <span>{props.pageTitle}</span>
              {props.includeRss && (
                <a
                  target="_blank"
                  href="/rss.xml"
                  class="rss-link inline-flex items-center"
                  aria-label="rss feed"
                  title="RSS Feed"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="rss-icon block h-6 w-6 shrink-0 fill-skin-base group-hover:fill-skin-accent"
                  >
                    <path d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z" />
                    <path d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z" />
                    <circle cx="6" cy="18" r="2" />
                  </svg>
                  <span class="sr-only">RSS Feed</span>
                </a>
              )}
            </h1>
          )}
          <p class="my-0">{props.pageDesc}</p>
        </>
      )
    }
    {
      fillViewportSlot ? (
        <div class="workshop-viewport-fill">
          <slot />
        </div>
      ) : (
        <slot />
      )
    }
  </main>
</RisoBoardShell>
