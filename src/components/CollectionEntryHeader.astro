---
interface Props {
  title: string;
  summary?: string;
  slug: string;
  /** Blog posts: serif title like index cards, larger for h1 (see `.post-page-title` in riso.css). */
  variant?: "default" | "blog";
}

const { title, summary, slug, variant = "default" } = Astro.props;
---

<h1
  transition:name={slug}
  class:list={[
    "collection-entry-title",
    "inline-block",
    variant === "blog" && "post-page-title",
  ]}
>
  {title}
</h1>
{summary && <p class="my-6 text-lg leading-6">{summary}</p>}

<style>
  .collection-entry-title:not(.post-page-title) {
    @apply mb-4 text-skin-accent;
  }
  .post-page-title {
    @apply mb-4;
  }
</style>
