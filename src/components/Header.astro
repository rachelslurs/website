---
import { LOGO_IMAGE, SITE } from "@config";
export interface Props {
  activeNav?: "posts" | "about" | "search" | "work" | "demos";
}

const { activeNav } = Astro.props;
---

<header>
  <a id="skip-to-content" href="#main-content">Skip to content</a>
  <div class="nav-container app-layout">
    <div class="top-nav-wrap">
      <a href="/" class="logo z-20 whitespace-nowrap">
        {
          LOGO_IMAGE.enable ? (
            <img
              src={`/assets/${LOGO_IMAGE.svg ? "logo.svg" : "logo.png"}`}
              alt={SITE.title}
              width={LOGO_IMAGE.width}
              height={LOGO_IMAGE.height}
            />
          ) : (
            <span class="dymo dymo-lg is-interactive">
              <span class="dymo-text">{SITE.title.toUpperCase()}</span>
            </span>
          )
        }
      </a>

      <button
        class="hamburger-menu focus-outline z-20"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="menu-icon"
        >
          <line x1="7" y1="12" x2="21" y2="12" class="line"></line>
          <line x1="3" y1="6" x2="21" y2="6" class="line"></line>
          <line x1="12" y1="18" x2="21" y2="18" class="line"></line>
          <line x1="18" y1="6" x2="6" y2="18" class="close"></line>
          <line x1="6" y1="6" x2="18" y2="18" class="close"></line>
        </svg>
      </button>
    </div>

    <nav id="nav-menu" class="mobile-menu-wrapper">
      <ul id="menu-items" class="sm:flex">
        <li>
          <a
            href="/posts"
            class:list={[
              "dymo",
              "is-interactive",
              { active: activeNav === "posts" },
            ]}
          >
            <span class="dymo-text">POSTS</span>
          </a>
        </li>
        <li>
          <a
            href="/demos"
            class:list={[
              "dymo",
              "is-interactive",
              { active: activeNav === "demos" },
            ]}
          >
            <span class="dymo-text">DEMOS</span>
          </a>
        </li>
        <li>
          <a
            href="/work"
            class:list={[
              "dymo",
              "is-interactive",
              { active: activeNav === "work" },
            ]}
          >
            <span class="dymo-text">WORK</span>
          </a>
        </li>
        <li>
          <a
            href="/about"
            class:list={[
              "dymo",
              "is-interactive",
              { active: activeNav === "about" },
            ]}
          >
            <span class="dymo-text">ABOUT</span>
          </a>
        </li>
        <li>
          <a
            href="/search"
            class:list={[
              "dymo",
              "is-interactive",
              "flex",
              "items-center",
              "p-3",
              "sm:p-1",
              { active: activeNav === "search" },
            ]}
            aria-label="Search"
            title="Search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="inline-block h-5 w-5 scale-125 text-white sm:scale-100"
              ><path
                fill="currentColor"
                d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
              ></path>
            </svg>
            <span class="sr-only">Search</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  #skip-to-content {
    @apply absolute -top-full left-16 z-50 bg-skin-accent px-3 py-2 text-skin-inverted transition-all focus:top-4;
  }
  .nav-container {
    @apply flex flex-col items-center justify-between sm:flex-row;
  }
  .top-nav-wrap {
    @apply relative flex w-full items-center justify-between py-4 sm:w-auto sm:py-8;
  }
  .logo {
    @apply sm:static;
  }
  .hamburger-menu {
    @apply p-2 sm:hidden;
  }

  /* ANIMATION LOGIC 
  */
  .mobile-menu-wrapper {
    @apply w-full overflow-hidden transition-all duration-300 ease-in-out sm:w-auto sm:overflow-visible;
    max-height: 0;
    opacity: 0;
    visibility: hidden; /* Prevents focusable elements from being clicked while closed */
  }

  .mobile-menu-wrapper.is-active {
    max-height: 350px; /* Reduced to match actual height more closely */
    opacity: 1;
    visibility: visible;
    @apply mb-6 sm:mb-0;
  }

  @media (min-width: 640px) {
    .mobile-menu-wrapper {
      max-height: none;
      opacity: 1;
      visibility: visible;
    }
  }

  nav ul {
    @apply mx-auto mt-4 flex max-w-md flex-wrap items-center justify-center gap-2 rounded-lg border border-skin-line/10 bg-skin-fill/50 p-2;
    @apply sm:mx-0 sm:mt-0 sm:max-w-none sm:border-none sm:bg-transparent sm:p-0;
  }

  nav ul li {
    @apply flex items-center justify-center;
  }
  nav ul li a.dymo {
    @apply my-0;
  }

  .menu-icon line {
    @apply transition-opacity duration-75 ease-in-out;
  }
  .menu-icon .close {
    opacity: 0;
  }
  .menu-icon.is-active .line {
    @apply opacity-0;
  }
  .menu-icon.is-active .close {
    @apply opacity-100;
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector(".hamburger-menu");
    const menuIcon = document.querySelector(".menu-icon");
    const menuWrapper = document.querySelector(".mobile-menu-wrapper");

    menuBtn?.addEventListener("click", () => {
      const menuExpanded = menuBtn.getAttribute("aria-expanded") === "true";

      // Update ARIA first
      menuBtn.setAttribute("aria-expanded", menuExpanded ? "false" : "true");
      menuBtn.setAttribute(
        "aria-label",
        menuExpanded ? "Open Menu" : "Close Menu"
      );

      // Toggle classes to trigger CSS transitions
      menuIcon?.classList.toggle("is-active");
      menuWrapper?.classList.toggle("is-active");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
