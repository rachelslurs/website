---
import { SITE } from "@config";
import RisoNav from "@components/RisoNav";
import Footer from "@components/Footer.astro";

export interface Props {
  /** Staggered Dymo nav entrance (homepage only). */
  animateNav?: boolean;
  /** Reading-progress bar for detail layouts; width is driven by the
   *  scroll handler in Layout.astro. */
  readingProgress?: boolean;
}

const { animateNav = false, readingProgress = false } = Astro.props;
---

<a id="skip-to-content" href="#main-content" class="skip-to-content-board">
  Skip to content
</a>
{
  readingProgress && (
    <div class="progress-container pointer-events-none fixed top-0 z-[9999] h-1 w-full bg-transparent">
      <div class="progress-bar h-1 w-0 bg-skin-accent" id="myBar" />
    </div>
  )
}
<div
  class="board-page-outer mx-auto flex min-h-0 w-full max-w-[1200px] flex-1 flex-col p-4 max-sm:p-2"
>
  <div
    class="board relative flex min-h-0 flex-1 flex-col gap-8 px-10 pb-10 pt-8 max-lg:p-6 max-sm:gap-5 max-sm:p-4"
  >
    <!-- Persist grain + blobs only: full-shell persist breaks in-page link navigation. -->
    <div
      class="pointer-events-none absolute inset-0 z-[100] overflow-hidden"
      aria-hidden="true"
      transition:persist="riso-board-decoration"
    >
      <div class="grain"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="blob blob-4"></div>
    </div>

    <div class="relative z-[110] flex min-h-0 flex-1 flex-col gap-8">
      <!-- client:idle — the nav is fully server-rendered (active state from
           activePath, entrance via CSS); hydration only adds the
           astro:page-load active-link sync, so it can wait out the LCP. -->
      <RisoNav
        client:idle
        activePath={Astro.url.pathname}
        siteTitle={SITE.title}
        animateEntrance={animateNav}
      />
      <!-- z-[60]: content paints above the nav (z-50) and footer, so a
           dragged board card (z-9999, trapped in this wrapper's stacking
           context by its view-transition-name) is never covered. -->
      <div
        transition:name="board-content"
        class="z-[60] flex min-h-0 flex-1 flex-col"
      >
        <slot />
      </div>
      <Footer />
    </div>
  </div>
</div>

<script is:inline>
  /** Skip link: instant scroll (avoid animating past chrome; matches user expectation). */
  (function initSkipToContent() {
    function bind() {
      const skip = document.getElementById("skip-to-content");
      if (!skip || skip.dataset.skipInstantBound) return;
      skip.dataset.skipInstantBound = "true";
      skip.addEventListener("click", e => {
        e.preventDefault();
        const main = document.getElementById("main-content");
        if (!main) return;
        const hadTabindex = main.hasAttribute("tabindex");
        if (!hadTabindex) main.setAttribute("tabindex", "-1");
        main.scrollIntoView({ behavior: "auto", block: "start" });
        main.focus({ preventScroll: true });
        if (!hadTabindex) {
          main.addEventListener(
            "blur",
            () => main.removeAttribute("tabindex"),
            { once: true }
          );
        }
        history.replaceState(null, "", "#main-content");
      });
    }
    bind();
    const afterSwapKey = "__skipToContentAfterSwap";
    if (!globalThis[afterSwapKey]) {
      globalThis[afterSwapKey] = true;
      document.addEventListener("astro:after-swap", bind);
    }
  })();
</script>
