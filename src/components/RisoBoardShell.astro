---
import { SITE } from "@config";
import RisoNav from "@components/RisoNav";
import Footer from "@components/Footer.astro";

export interface Props {
  /** Staggered Dymo nav entrance (homepage only). */
  animateNav?: boolean;
  /**
   * When true: shell fills at least the viewport height so nested `min-h-0` + flex
   * pegboard regions scroll internally (ADR-003). Used by workshop via Main.
   */
  fillViewportChain?: boolean;
  /**
   * Pilot (ADR-011 / ADR-010): drop outer `max-w-[1200px]` so the peg field can use
   * the full viewport width; inner `board` column + ADR-008 decoration bounds unchanged.
   */
  immersivePegStage?: boolean;
}

const {
  animateNav = false,
  fillViewportChain = false,
  immersivePegStage = false,
} = Astro.props;

/** Immersive pilot (workshop): reclaim vertical budget for peg column without changing other routes. */
const boardBlockPadding = immersivePegStage
  ? "max-sm:py-board-padding-sm max-lg:py-4 lg:pt-5 lg:pb-6"
  : "max-lg:py-board-padding-y-lg lg:pb-board-pb-lg lg:pt-board-pt-lg";

const stackChromeGap = immersivePegStage
  ? "gap-board-stack-gap-lg max-sm:gap-board-stack-gap-sm"
  : "gap-board-stack-gap max-lg:gap-board-stack-gap-lg max-sm:gap-board-stack-gap-sm";
---

<a id="skip-to-content" href="#main-content" class="skip-to-content-board">
  Skip to content
</a>
<div
  class:list={[
    "board-page-outer w-full",
    immersivePegStage
      ? "py-board-outer-sm px-0"
      : "p-board-outer max-sm:p-board-outer-sm",
    immersivePegStage && "board-page-outer--immersive-peg-stage",
    immersivePegStage ? "max-w-none" : "mx-auto max-w-[1200px]",
    /* min-h-dvh alone leaves height indefinite for flex descendants on some engines;
     * h-svh fixes the workshop pegboard column (ADR-003). */
    fillViewportChain && "flex h-svh min-h-0 flex-col",
  ]}
>
  {immersivePegStage && <div class="peg-stage-underlay" aria-hidden="true" />}
  <!-- ADR-008 (+ ADR-011): page-owned visuals (tape, edges, etc.) stay inside the inner `board` column. -->
  <div
    class:list={[
      "board relative flex flex-col gap-board-slab-gap max-sm:gap-board-slab-gap-sm",
      boardBlockPadding,
      immersivePegStage
        ? "px-0 max-sm:px-0"
        : "px-board-padding-x max-sm:p-board-padding-sm",
      fillViewportChain && "min-h-0 flex-1",
    ]}
  >
    <!-- Persist grain + blobs only: full-shell persist breaks in-page link navigation. -->
    <div
      class="pointer-events-none absolute inset-0 z-[100] overflow-hidden"
      aria-hidden="true"
      transition:persist="riso-board-decoration"
    >
      <div class="grain"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="blob blob-4"></div>
    </div>

    <div
      class:list={[
        "relative z-[110] flex min-h-0 flex-1 flex-col",
        stackChromeGap,
      ]}
    >
      <RisoNav
        client:load
        activePath={Astro.url.pathname}
        siteTitle={SITE.title}
        animateEntrance={animateNav}
      />
      <div
        transition:name="board-content"
        class:list={[
          "min-h-0 flex-1",
          fillViewportChain && "flex min-h-0 flex-col",
        ]}
      >
        <slot />
      </div>
      <Footer />
    </div>
  </div>
</div>

<script is:inline>
  /** Skip link: instant scroll (avoid animating past chrome; matches user expectation). */
  (function initSkipToContent() {
    function bind() {
      const skip = document.getElementById("skip-to-content");
      if (!skip || skip.dataset.skipInstantBound) return;
      skip.dataset.skipInstantBound = "true";
      skip.addEventListener("click", e => {
        e.preventDefault();
        const main = document.getElementById("main-content");
        if (!main) return;
        const hadTabindex = main.hasAttribute("tabindex");
        if (!hadTabindex) main.setAttribute("tabindex", "-1");
        main.scrollIntoView({ behavior: "auto", block: "start" });
        main.focus({ preventScroll: true });
        if (!hadTabindex) {
          main.addEventListener(
            "blur",
            () => main.removeAttribute("tabindex"),
            { once: true }
          );
        }
        history.replaceState(null, "", "#main-content");
      });
    }
    bind();
    const afterSwapKey = "__skipToContentAfterSwap";
    if (!globalThis[afterSwapKey]) {
      globalThis[afterSwapKey] = true;
      document.addEventListener("astro:after-swap", bind);
    }
  })();
</script>
