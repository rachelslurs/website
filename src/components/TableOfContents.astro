---
import type { MarkdownHeading } from "astro";
import { filterTocHeadings } from "@utils/filterTocHeadings";
import tocScrollBehavior from "./toc-scroll-behavior.js?raw";

export interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const tocItems = filterTocHeadings(headings).map(h => ({
  id: h.slug,
  level: h.depth,
  text: h.text,
}));
---

{
  tocItems.length > 0 && (
    <>
      <nav
        class="library-card-toc pushpin pp-blk"
        aria-label="Table of contents"
        data-toc-root
        data-toc-items={JSON.stringify(tocItems)}
      >
        <div class="toc-header">CONTENTS</div>
        <ul class="toc-list">
          {tocItems.map(item => (
            <li
              class="toc-item"
              data-toc-depth={item.level}
              style={{ paddingLeft: `${Math.max(0, item.level - 2) * 1}rem` }}
              data-toc-id={item.id}
            >
              <a href={`#${item.id}`} class="toc-link">
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <script is:inline set:html={tocScrollBehavior} />
    </>
  )
}
