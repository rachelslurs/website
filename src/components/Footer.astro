---
import { SOCIALS } from "@config";

const FOOTER_LABEL: Record<string, string> = {
  GitHub: "GITHUB",
  LinkedIn: "LINKEDIN",
};

const footerSocials = SOCIALS.filter(s => s.active);
---

<footer
  id="about"
  class="flex flex-wrap items-center justify-center gap-3 pt-4 sm:justify-end"
  role="contentinfo"
>
  <div class="flex gap-1.5" role="list" aria-label="Social links">
    {
      footerSocials.map(social => (
        <div role="listitem">
          <a
            href={social.href}
            class="dymo is-interactive"
            rel="noopener noreferrer"
            target="_blank"
            aria-label={social.linkTitle.trim()}
          >
            <span class="dymo-text" aria-hidden="true">
              {FOOTER_LABEL[social.name] ?? social.name.toUpperCase()}
            </span>
          </a>
        </div>
      ))
    }
  </div>
</footer>
