---
import { SOCIALS } from "@config";

const FOOTER_LABEL: Record<string, string> = {
  GitHub: "GITHUB",
  LinkedIn: "LINKEDIN",
};

const footerSocials = SOCIALS.filter(s => s.active);
---

<footer
  id="about"
  class="flex flex-wrap items-center justify-center gap-footer-gap pt-footer-pt max-sm:pt-footer-pt-sm sm:justify-end"
  role="contentinfo"
>
  <ul
    class="flex list-none flex-wrap items-center justify-center gap-footer-links-gap"
    role="list"
    aria-label="Social links"
  >
    {
      footerSocials.map(social => (
        <li>
          <a
            href={social.href}
            class="dymo is-interactive"
            rel="noopener noreferrer"
            target="_blank"
            aria-label={social.linkTitle.trim()}
          >
            <span class="dymo-text" aria-hidden="true">
              {FOOTER_LABEL[social.name] ?? social.name.toUpperCase()}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</footer>
